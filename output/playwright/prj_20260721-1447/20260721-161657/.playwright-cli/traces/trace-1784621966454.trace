rmat.\\\" - \\\"Direct identifiers are excluded.\\\" inference: kind: \\\"inferred_supporting_field\\\" rationale: \\\"A pseudonymous record key is directly implied by multicentre screening and CRF data management.\\\" confidence_percent: 90 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"screening_date\\\" label: \\\"Screening date\\\" purpose: \\\"Record when eligibility screening was performed.\\\" data_type: \\\"date\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Recruitment and screening, page 3\\\" confidence: \\\"medium\\\" notes: - \\\"A screening date is implied but not explicitly named as a CRF field.\\\" inference: kind: \\\"inferred_supporting_field\\\" rationale: \\\"A dated screening assessment is necessary to evaluate look-back periods stated by the protocol.\\\" confidence_percent: 90 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"inc01_informed_consent\\\" label: \\\"Informed consent inclusion criterion met\\\" purpose: \\\"Confirm that informed consent has been obtained.\\\" data_type: \\\"boolean\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Inclusion criteria item 1, page 2\\\" confidence: \\\"high\\\" - locator: \\\"Ethical issues and dissemination, page 7\\\" confidence: \\\"high\\\" notes: [] inference: kind: \\\"protocol_explicit\\\" rationale: null confidence_percent: 100 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"age_years\\\" label: \\\"Age\\\" purpose: \\\"Record age in years as evidence for the ag