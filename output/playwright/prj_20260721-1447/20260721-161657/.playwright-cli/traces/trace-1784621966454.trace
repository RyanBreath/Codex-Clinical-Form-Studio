\\" title: \\\"Sleep Respiratory Assessment\\\" purpose: \\\"Capture protocol-named polysomnography and sleep respiratory outcomes.\\\" visit: \\\"baseline, 3 months, 6 months, and 12 months\\\" source_refs: - locator: \\\"Secondary endpoints - sleep variables, page 4\\\" confidence: \\\"high\\\" - locator: \\\"Sleep respiratory variables, page 5\\\" confidence: \\\"high\\\" - candidate_id: \\\"laboratory-biomarkers-specimens\\\" title: \\\"Laboratory, Biomarker, and Specimen Assessment\\\" purpose: \\\"Capture protocol-named biochemical, inflammatory, anti-inflammatory, oxidative-stress, urine, blood, faecal, metabolomic, and microbiome assessments.\\\" visit: \\\"baseline, 3 months, 6 months, and 12 months\\\" source_refs: - locator: \\\"Other outcomes - biochemical variables, pages 4-5\\\" confidence: \\\"high\\\" - locator: \\\"Urine, blood, and faecal samples, page 5\\\" confidence: \\\"high\\\" - candidate_id: \\\"anthropometry-cardiopulmonary\\\" title: \\\"Anthropometry and Cardiopulmonary Assessment\\\" purpose: \\\"Capture anthropometry, blood pressure, echocardiography, arterial stiffness, pulmonary function, and ECG assessments.\\\" visit: \\\"baseline and follow-up; lung-function and ECG schedule unresolved\\\" source_refs: - locator: \\\"Oxidative stress index and study examination procedures, page 5\\\" confidence: \\\"high\\\" - candidate_id: \\\"auditory-eeg-assessment\\\" title: \\\"Auditory and High-Density EEG Assessment\\\" purpose: \\\"Capture audiometry, DPOAE, central auditory processing tests, and protocol-specified EEG task results.\\\" visit: \\\"baseline, 3 months, 6 months, and 12 months\\\" source_refs: - locator: \\\"Auditory testing, pages 4-5\\\" confidence: \\\"high\\\" - locator: \\\"256-channel high-density EEG recording, pages 5-6\\\" confidence: \\\"high\\\" - candidate_id: \\\"brain-imaging-mrs\\\" title: \\\"Brain Imaging and Magnetic Resonance Spectroscopy\\\" purpose: \\\"Capture structural MRI, resting-state fMRI, diffusion