nding.\\\" - concept_id: \\\"exc10_recent_gastrointestinal_surgery\\\" label: \\\"Gastrointestinal surgery during the last year exclusion criterion present\\\" purpose: \\\"Record gastrointestinal surgery within the look-back period, excluding appendicitis and hernia surgery.\\\" data_type: \\\"boolean\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Exclusion criteria item 10, page 3\\\" confidence: \\\"high\\\" notes: - \\\"The protocol wording is retained; whether 'appendicitis surgery' means appendectomy requires clinical confirmation.\\\" inference: kind: \\\"protocol_explicit\\\" rationale: null confidence_percent: 100 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"exc11_pregnancy\\\" label: \\\"Pregnancy exclusion criterion present\\\" purpose: \\\"Record pregnancy status for eligibility.\\\" data_type: \\\"boolean\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Exclusion criteria item 11, page 3\\\" confidence: \\\"high\\\" notes: [] inference: kind: \\\"protocol_explicit\\\" rationale: null confidence_percent: 100 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"exc12_recent_intestinal_flora_regulator\\\" label: \\\"Intestinal flora regulator use during the previous 8 weeks exclusion criterion present\\\" purpose: \\\"Record recent use of an intestinal flora regulator.\\\" data_type: \\\"boolean\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Exclusion criteria item 12, page 3\\\" confidence: \\\"high\\\" notes: - \\\"Antibiotics and probiotics are exampl