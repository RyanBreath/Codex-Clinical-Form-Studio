\\" title: \\\"Sleep Respiratory Assessment\\\" purpose: \\\"Capture protocol-named polysomnography and sleep respiratory outcomes.\\\" visit: \\\"baseline, 3 months, 6 months, and 12 months\\\" source_refs: - locator: \\\"Secondary endpoints - sleep variables, page 4\\\" confidence: \\\"high\\\" - locator: \\\"Sleep respiratory variables, page 5\\\" confidence: \\\"high\\\" - candidate_id: \\\"laboratory-biomarkers-specimens\\\" title: \\\"Laboratory, Biomarker, and Specimen Assessment\\\" purpose: \\\"Capture protocol-named biochemical, inflammatory, anti-inflammatory, oxidative-stress, urine, blood, faecal, metabolomic, and microbiome assessments.\\\" visit: \\\"baseline, 3 months, 6 months, and 12 months\\\" source_refs: - locator: \\\"Other outcomes - biochemical variables, pages 4-5\\\" confidence: \\\"high\\\" - locator: \\\"Urine, blood, and faecal samples, page 5\\\" confidence: \\\"high\\\" - candidate_id: \\\"anthropometry-cardiopulmonary\\\" title: \\\"Anthropometry and Cardiopulmonary Assessment\\\" purpose: \\\"Capture anthropometry, blood pressure, echocardiography, arterial stiffness, pulmonary function, and ECG assessments.\\\" visit: \\\"baseline and follow-up; lung-function and ECG schedule unresolved\\\" source_refs: - locator: \\\"Oxidative stress index and study examination procedures, page 5\\\" confidence: \\\"high\\\" - candidate_id: \\\"auditory-eeg-assessment\\\" title: \\\"Auditory and High-Density EEG Assessment\\\" purpose: \\\"Capture audiometry, DPOAE, central auditory processing tests, and protocol-specified EEG task results.\\\" visit: \\\"baseline, 3 months, 6 months, and 12 months\\\" source_refs: - locator: \\\"Auditory testing, pages 4-5\\\" confidence: \\\"high\\\" - locator: \\\"256-channel high-density EEG recording, pages 5-6\\\" confidence: \\\"high\\\" - candidate_id: \\\"brain-imaging-mrs\\\" title: \\\"Brain Imaging and Magnetic Resonance Spectroscopy\\\" purpose: \\\"Capture structural MRI, resting-state fMRI, diffusion imaging, and cerebral metabolite assessment status and results.\\\" visit: \\\"baseline, 3 months, 6 months, and 12 months\\\" source_refs: - locator: \\\"Secondary endpoints, page 4\\\" confidence: \\\"high\\\" - locator: \\\"Brain imaging and cerebral metabolites, page 6\\\" confidence: \\\"high\\\" - candidate_id: \\\"cpap-compliance\\\" title: \\\"CPAP Treatment and Compliance\\\" purpose: \\\"Capture CPAP exposure and device-derived adherence information for the CPAP plus BSC group.\\\" visit: \\\"during intervention and follow-up\\\" source_refs: - locator: \\\"CPAP plus BSC group and Follow-up, page 4\\\" confidence: \\\"high\\\" - candidate_id: \\\"adverse-events\\\" title: \\\"Adverse Events\\\" purpose: \\\"Capture unexpected adverse events associated with CPAP, including severity, causality, and serious-event reporting.\\\" visit: \\\"during the OSA treatment period\\\" source_refs: - locator: \\\"Safety measurements, page 6\\\" confidence: \\\"high\\\" - candidate_id: \\\"withdrawal-disposition\\\" title: \\\"Withdrawal and Disposition\\\" purpose: \\\"Document protocol-specified withdrawal circumstances and study disposition.\\\" visit: \\\"as needed\\\" source_refs: - locator: \\\"Withdrawal criteria, page 3\\\" confidence: \\\"high\\\" selected_form: candidate_id: \\\"screening-eligibility\\\" approval_status: \\\"pending\\\" purpose: \\\"Document diagnostic, inclusion, and exclusion criteria before enrolment and randomisation.\\\" visit: \\\"screening\\\" fields: - concept_id: \\\"study_identifier\\\" label: \\\"Study identifier\\\" purpose: \\\"Display or prepopulate the unique study identifier on the screening eCRF.\\\" data_type: \\\"string\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Protocol title and trial registration, page 1; multicentre data management, pages 6-7\\\" confidence: \\\"medium\\\" notes: - \\\"The protocol does not identify which value