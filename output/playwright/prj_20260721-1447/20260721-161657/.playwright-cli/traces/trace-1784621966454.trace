" label: \\\"Commercial driver or driving-related accident risk exclusion criterion present\\\" purpose: \\\"Record the protocol-specified occupational or driving-risk exclusion.\\\" data_type: \\\"boolean\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Exclusion criteria item 15, page 3\\\" confidence: \\\"high\\\" notes: [] inference: kind: \\\"protocol_explicit\\\" rationale: null confidence_percent: 100 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"exc16_investigator_unsuitable\\\" label: \\\"Investigator deems participant unsuitable\\\" purpose: \\\"Record the investigator's protocol-defined unsuitability decision.\\\" data_type: \\\"boolean\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Exclusion criteria item 16, page 3\\\" confidence: \\\"high\\\" notes: [] inference: kind: \\\"protocol_explicit\\\" rationale: null confidence_percent: 100 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"investigator_unsuitable_reason\\\" label: \\\"Reason participant is deemed unsuitable\\\" purpose: \\\"Document the rationale when the investigator applies the general unsuitability exclusion.\\\" data_type: \\\"string\\\" required: null unit: null range: null options: [] visible_when: concept_id: \\\"exc16_investigator_unsuitable\\\" equals: true required_when: null calculation: null source_refs: - locator: \\\"Exclusion criteria item 16, page 3\\\" confidence: \\\"medium\\\" notes: - \\\"The protocol does not explicitly require a recorded reason.\\\" inference: kind: \\\"inferred_supporting_field\\\" rationale: \\\"A reason is directly implied by an investigator-specific unsuitability determination and supports auditability.\\\" confidence_percent: 90 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" - concept_id: \\\"eligible_for_randomisation\\\" label: \\\"Eligible for randomisation\\\" purpose: \\\"Record the final screening determination after all inclusion and exclusion criteria are reviewed.\\\" data_type: \\\"boolean\\\" required: null unit: null range: null options: [] visible_when: null required_when: null calculation: null source_refs: - locator: \\\"Flow diagram, page 3; Randomisation, allocation concealment and blinding, page 4\\\" confidence: \\\"medium\\\" notes: - \\\"The field is proposed as a manually confirmed determination because the renderer contract does not support a safe Boolean eligibility calculation.\\\" inference: kind: \\\"inferred_supporting_field\\\" rationale: \\\"The protocol explicitly transitions eligible screened patients to randomisation, which directly implies a final determination.\\\" confidence_percent: 95 coding: status: \\\"unresolved\\\" rationale: \\\"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\\\" unresolved_items: - id: \\\"U-001\\\" severity: \\\"warning\\\" question: \\\"Which single candidate form should be generated first?\\\" affected_concepts: - \\\"selected_form\\\" source_refs: - locator: \\\"Protocol-wide candidate-form inventory, pages 2-6\\\" resolution: \\\"The user selected screening-eligibility. This records form selection only and is not Gate A approval.\\\" resolved_by: \\\"user\\\" resolved_at: \\\"2026-07-21T06:57:16.5844044Z\\\" - id: \\\"U-002\\\" severity: \\\"warning\\\" question: \\\"What protocol version and protocol date should be recorded? The journal publication year and online publication date are not labelled as the protocol version/date.\\\" affected_concepts: - \\\"source.protocol_version\\\" - \\\"source.protocol_date\\\" source_refs: - locator: \\\"Article header, page 1\\\" resolution: null resolved_by: null resolved_at: null - id: \\\"U-003\\\" severity: \\\"blocking\\\" question: \\\"For the selected form, which fields are mandatory? The protocol generally does not state field-level requiredness.\\\" affected_concepts: - \\\"selected_form.fields.required\\\" source_refs: - locator: \\\"Outcome assessment and study examination procedures, pages 4-6\\\" resolution: \\\"The user approved the Gate A proposal: all core screening fields are required; investigator_unsuitable_reason is conditionally required when exc16 is Y; calculated BMI is read-only and is not independently required.\\\" resolved_by: \\\"user decision in Codex task\\\" resolved_at: \\\"2026-07-21\\\" - id: \\\"U-004\\\" severity: \\\"blocking\\\" question: \\\"For the selected form, confirm the data types, units, precision, and edit-check ranges that the protocol does not explicitly define.\\\" affected_concepts: - \\\"selected_form.fields.data_type\\\" - \\\"selected_form.fields.unit\\\" - \\\"selected_form.fields.range\\\" source_refs: - locator: \\\"Outcome and procedure descriptions, pages 4-6\\\" resolution: \\\"The user approved the proposed data types, protocol units and threshold consistency checks. Unstated plausible-data ranges and precision remain unset; BMI displays two decimal places per the user's implementation request.\\\" resolved_by: \\\"user decision in Codex task\\\" resolved_at: \\\"2026-07-21\\\" - id: \\\"U-005\\\" severity: \\\"warning\\\" question: \\\"At which visits are lung function and ECG performed? They are exceptions to the general baseline/3/6/12-month schedule, but the alternative schedule is not stated.\\\" affected_concepts: - \\\"lung_function.visit_schedule\\\" - \\\"ecg.visit_schedule\\\" source_refs: - locator: \\\"Study examination procedures, page 5\\\" resolution: null resolved_by: null resolved_at: null - id: \\\"U-006\\\" severity: \\\"blocking\\\" question: \\\"Should MoCA and MMSE be represented as total scores only, or should licensed item-level instruments be supplied separately? The protocol does not reproduce the item-level forms.\\\" affected_concepts: - \\\"moca\\\" - \\\"mmse\\\" source_refs: - locator: \\\"Basic characteristics and primary/secondary endpoints, page 4\\\" resolution: \\\"The user approved total-score-only MMSE capture for this screening form. No licensed item text is included.\\\" resolved_by: \\\"user decision in Codex task\\\" resolved_at: \\\"2026-07-21\\\" - id: \\\"U-007\\\" severity: \\\"warning\\\" question: \\\"Which device-derived CPAP adherence metrics must be collected? The protocol states that usage information is downloaded daily but does not define the variables.\\\" affected_concepts: - \\\"cpap_compliance\\\" source_refs: - locator: \\\"Follow-up, page 4\\\" resolution: null resolved_by: null resolved_at: null - id: \\\"U-008\\\" severity: \\\"warning\\\" question: \\\"Which adverse-event data elements and controlled values should be used beyond event occurrence, severity, causality, and serious-event escalation?\\\" affected_concepts: - \\\"adverse_events\\\" source_refs: - locator: \\\"Safety measurements, page 6\\\" resolution: null resolved_by: null resolved_at: null - id: \\\"U-009\\\" severity: \\\"warning\\\" question: \\\"The sleep-variable list ends with 'etc.'; confirm whether only explicitly named variables or an external PSG specification should define the complete form.\\\" affected_concepts: - \\\"sleep_respiratory_variables\\\" source_refs: - locator: \\\"Secondary endpoints - sleep variables, page 4\\\" resolution: null resolved_by: null resolved_at: null - id: \\\"U-010\\\" severity: \\\"blocking\\\" question: \\\"Confirm that CDASHIG v2.1 is the required mapping target for this form.\\\" affected_concepts: - \\\"selected_form.fields.coding\\\" source_refs: - locator: \\\"User workflow configuration; not a protocol-derived clinical fact\\\" resolution: \\\"The user confirmed CDASHIG v2.1 as the required mapping target.\\\" resolved_by: \\\"user\\\" resolved_at: \\\"2026-07-21T07:02:36.5931875Z\\\" - id: \\\"U-011\\\" severity: \\\"blocking\\\" question: \\\"Approve criterion-level Boolean fields plus separate evidence values for age, AHI, one-night CPAP use, and MMSE, so screen failures can be retained.\\\" affected_concepts: - \\\"inc02_age_30_to_65\\\" - \\\"inc03_osa_diagnostic_criterion\\\" - \\\"inc04_cpap_tolerance\\\" - \\\"exc07_mmse_below_24\\\" source_refs: - locator: \\\"Eligibility criteria, pages 2-3\\\" resolution: \\\"The user approved the full criterion worksheet plus separate evidence values for age, AHI, one-night CPAP use, and MMSE.\\\" resolved_by: \\\"user decision in Codex task\\\" resolved_at: \\\"2026-07-21\\\" - id: \\\"U-012\\\" severity: \\\"blocking\\\" question: \\\"Approve criterion-level capture for compound exclusions 5 and 13, or request separate evidence fields for each substance, medication, disease, and treatment.\\\" affected_concepts: - \\\"exc05_substance_or_restricted_medication\\\" - \\\"exc13_recent_treatment_listed_condition\\\" source_refs: - locator: \\\"Exclusion criteria items 5 and 13, pages 2-3\\\" resolution: \\\"The user approved retaining exclusions 5 and 13 as single compound protocol-level criteria.\\\" resolved_by: \\\"user decision in Codex task\\\" resolved_at: \\\"2026-07-21\\\" - id: \\\"U-013\\\" severity: \\\"blocking\\\" question: \\\"Confirm whether the final eligible-for-randomisation field should remain a manual investigator confirmation rather than an automatically calculated value.\\\" affected_concepts: - \\\"eligible_for_randomisation\\\" source_refs: - locator: \\\"Flow diagram, page 3; Randomisation, page 4\\\" resolution: \\\"The user approved a manual investigator eligibility determination with consistency checks; the form must not silently overwrite the decision.\\\" resolved_by: \\\"user decision in Codex task\\\" resolved_at: \\\"2