col for a multicentre randomised controlled trial\"\n  protocol_version: \"unresolved\"\n  protocol_date: \"unresolved\"\n  publication_citation: \"BMJ Open 2017;7:e014932\"\n  trial_registration: \"NCT02886156\"\n  extraction_method: \"native-text\"\n  extracted_at: \"2026-07-21T06:50:10.4577228Z\"\n\nterminology_sources:\n  - standard: \"CDISC\"\n    model: \"CDASHIG\"\n    publication: \"Clinical Data Acquisition Standards Harmonization Implementation Guide for Human Clinical Trials\"\n    version: \"2.1\"\n    publication_date: \"2019-11-01\"\n    source_url: \"https://www.cdisc.org/standards/foundational/cdashig-v2-1\"\n    retrieved_at: \"2026-07-21T07:02:36.5931875Z\"\n  - standard: \"CDISC\"\n    model: \"Controlled Terminology\"\n    publication: \"CDISC Controlled Terminology - CDASH and SDTM\"\n    version: \"2026-03-27\"\n    source_url: \"https://www.cdisc.org/standards/terminology/controlled-terminology\"\n    retrieved_at: \"2026-07-21T07:02:36.5931875Z\"\n  - standard: \"CDISC\"\n    model: \"QRS Supplement\"\n    publication: \"Mini-Mental State Examination\"\n    version: \"1.0\"\n    publication_date: \"2024-12-12\"\n    source_url: \"https://www.cdisc.org/standards/foundational/qrs/mini-mental-state-examination\"\n    retrieved_at: \"2026-07-21T07:02:36.5931875Z\"\n    access_note: \"The official page confirms the FT domain, MMSE category, version, and release date; detailed supplement files require authenticated CDISC access.\"\n  - standard: \"CDISC/NCI EVS\"\n    model: \"SDTM Controlled Terminology\"\n    publication: \"SDTM Terminology\"\n    version: \"2026-03-27\"\n    source_url: \"https://evs.nci.nih.gov/ftp1/CDISC/SDTM/SDTM%20Terminology.txt\"\n    retrieved_at: \"2026-07-21T07:02:36.5931875Z\"\n    sha256: \"bf463677654171d701d09ffcb0a122e9523029b42d542269f45fb496a35ecef9\"\n\nstudy_summary:\n  design: \"Multicentre, evaluator-blinded, randomised, parallel-controlled trial\"\n  planned_enrolment: 148\n  population: \"Han adults aged 30-65 years with newly diagnosed moderate-to-severe obstructive sleep apnoea\"\n  arms:\n    - \"CPAP plus best supportive care\"\n    - \"Best supportive care only\"\n  randomisation_ratio: \"1:1\"\n  scheduled_assessments:\n    - \"baseline before randomisation\"\n    - \"3 months\"\n    - \"6 months\"\n    - \"12 months\"\n  primary_endpoint: \"Montreal Cognitive Assessment (MoCA)\"\n\ncandidate_forms:\n  - candidate_id: \"screening-eligibility\"\n    title: \"Screening and Eligibility\"\n    purpose: \"Document diagnostic, inclusion, and exclusion criteria before enrolment.\"\n    visit: \"screening\"\n    source_refs:\n      - locator: \"Study population, diagnostic criteria, and eligible participants, pages 2-3\"\n        confidence: \"high\"\n  - candidate_id: \"baseline-characteristics\"\n    title: \"Baseline Characteristics\"\n    purpose: \"Collect age, sex, education, medical history, medication use, occupation, MoCA, and MMSE before randomisation.\"\n    visit: \"baseline\"\n    source_refs:\n      - locator: \"Basic characteristics, page 4\"\n        confidence: \"high\"\n  - candidate_id: \"randomisation\"\n    title: \"Randomisation\"\n    purpose: \"Record equal allocation to CPAP plus BSC or BSC only after eligibility and baseline assessment.\"\n    visit: \"baseline after assessments\"\n    source_refs:\n      - locator: \"Randomisation, allocation concealment and blinding, page 4\"\n        confidence: \"high\"\n  - candidate_id: \"neurocognitive-assessment\"\n    title: \"Neurocognitive Assessment\"\n    purpose: \"Capture the primary MoCA endpoint, MMSE, and named neuropsychological test results.\"\n    visit: \"baseline, 3 months, 6 months, and 12 months\"\n    source_refs:\n      - locator: \"Primary and secondary outcomes, page 4\"\n        confidence: \"high\"\n      - locator: \"Neuropsychological tests, page 5\"\n        confidence: \"high\"\n  - candidate_id: \"sleep-respiratory-assessment\"\n    title: \"Sleep Respiratory Assessment\"\n    purpose: \"Capture protocol-named polysomnography and sleep respiratory outcomes.\"\n    visit: \"baseline, 3 months, 6 months, and 12 months\"\n    source_refs:\n      - locator: \"Secondary endpoints - sleep variables, page 4\"\n        confidence: \"high\"\n      - locator: \"Sleep respiratory variables, page 5\"\n        confidence: \"high\"\n  - candidate_id: \"laboratory-biomarkers-specimens\"\n    title: \"Laboratory, Biomarker, and Specimen Assessment\"\n    purpose: \"Capture protocol-named biochemical, inflammatory, anti-inflammatory, oxidative-stress, urine, blood, faecal, metabolomic, and microbiome assessments.\"\n    visit: \"baseline, 3 months, 6 months, and 12 months\"\n    source_refs:\n      - locator: \"Other outcomes - biochemical variables, pages 4-5\"\n        confidence: \"high\"\n      - locator: \"Urine, blood, and faecal samples, page 5\"\n        confidence: \"high\"\n  - candidate_id: \"anthropometry-cardiopulmonary\"\n    title: \"Anthropometry and Cardiopulmonary Assessment\"\n    purpose: \"Capture anthropometry, blood pressure, echocardiography, arterial stiffness, pulmonary function, and ECG assessments.\"\n    visit: \"baseline and follow-up; lung-function and ECG schedule unresolved\"\n    source_refs:\n      - locator: \"Oxidative stress index and study examination procedures, page 5\"\n        confidence: \"high\"\n  - candidate_id: \"auditory-eeg-assessment\"\n    title: \"Auditory and High-Density EEG Assessment\"\n    purpose: \"Capture audiometry, DPOAE, central auditory processing tests, and protocol-specified EEG task results.\"\n    visit: \"baseline, 3 months, 6 months, and 12 months\"\n    source_refs:\n      - locator: \"Auditory testing, pages 4-5\"\n        confidence: \"high\"\n      - locator: \"256-channel high-density EEG recording, pages 5-6\"\n        confidence: \"high\"\n  - candidate_id: \"brain-imaging-mrs\"\n    title: \"Brain Imaging and Magnetic Resonance Spectroscopy\"\n    purpose: \"Capture structural MRI, resting-state fMRI, diffusion imaging, and cerebral metabolite assessment status and results.\"\n    visit: \"baseline, 3 months, 6 months, and 12 months\"\n    source_refs:\n      - locator: \"Secondary endpoints, page 4\"\n        confidence: \"high\"\n      - locator: \"Brain imaging and cerebral metabolites, page 6\"\n        confidence: \"high\"\n  - candidate_id: \"cpap-compliance\"\n    title: \"CPAP Treatment and Compliance\"\n    purpose: \"Capture CPAP exposure and device-derived adherence information for the CPAP plus BSC group.\"\n    visit: \"during intervention and follow-up\"\n    source_refs:\n      - locator: \"CPAP plus BSC group and Follow-up, page 4\"\n        confidence: \"high\"\n  - candidate_id: \"adverse-events\"\n    title: \"Adverse Events\"\n    purpose: \"Capture unexpected adverse events associated with CPAP, including severity, causality, and serious-event reporting.\"\n    visit: \"during the OSA treatment period\"\n    source_refs:\n      - locator: \"Safety measurements, page 6\"\n        confidence: \"high\"\n  - candidate_id: \"withdrawal-disposition\"\n    title: \"Withdrawal and Disposition\"\n    purpose: \"Document protocol-specified withdrawal circumstances and study disposition.\"\n    visit: \"as needed\"\n    source_refs:\n      - locator: \"Withdrawal criteria, page 3\"\n        confidence: \"high\"\n\nselected_form:\n  candidate_id: \"screening-eligibility\"\n  approval_status: \"pending\"\n  purpose: \"Document diagnostic, inclusion, and exclusion criteria before enrolment and randomisation.\"\n  visit: \"screening\"\n  fields:\n    - concept_id: \"study_identifier\"\n      label: \"Study identifier\"\n      purpose: \"Display or prepopulate the unique study identifier on the screening eCRF.\"\n      data_type: \"string\"\n      required: null\n      unit: null\n      range: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Protocol title and trial registration, page 1; multicentre data management, pages 6-7\"\n          confidence: \"medium\"\n      notes:\n        - \"The protocol does not identify which value is the sponsor's STUDYID; the trial registration number must not be substituted without approval.\"\n        - \"This should be system-prepopulated rather than manually entered.\"\n      inference:\n        kind: \"inferred_supporting_field\"\n        rationale: \"A study identifier is directly implied by the named trial and its CRF data-management process.\"\n        confidence_percent: 95\n      coding:\n        status: \"unresolved\"\n        rationale: \"Official candidate IE.STUDYID identified; specialist selection and the actual sponsor study identifier remain pending.\"\n    - concept_id: \"site_identifier\"\n      label: \"Site identifier\"\n      purpose: \"Display or prepopulate the identifier of the participating sleep centre.\"\n      data_type: \"string\"\n      required: null\n      unit: null\n      range: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Study design and five participating sleep centres, page 2; data collection and management, pages 6-7\"\n          confidence: \"high\"\n      notes:\n        - \"The protocol names the centres but does not define site codes.\"\n        - \"This should be system-prepopulated rather than manually entered.\"\n      inference:\n        kind: \"inferred_supporting_field\"\n        rationale: \"A site identifier is directly implied by the multicentre design and centre-specific web CRF storage.\"\n        confidence_percent: 95\n      coding:\n        status: \"unresolved\"\n        rationale: \"Official candidate IE.SITEID identified; specialist selection and site codes remain pending.\"\n    - concept_id: \"screening_record_code\"\n      label: \"Pseudonymous screening record code\"\n      purpose: \"Link the screening assessment without collecting a direct participant identifier.\"\n      data_type: \"string\"\n      required: null\n      unit: null\n      range: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Recruitment and screening, page 3; data collection and management, pages 6-7\"\n          confidence: \"medium\"\n      notes:\n        - \"The protocol does not define the code format.\"\n        - \"Direct identifiers are excluded.\"\n      inference:\n        kind: \"inferred_supporting_field\"\n        rationale: \"A pseudonymous record key is directly implied by multicentre screening and CRF data management.\"\n        confidence_percent: 90\n      coding:\n        status: \"unresolved\"\n        rationale: \"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\"\n    - concept_id: \"screening_date\"\n      label: \"Screening date\"\n      purpose: \"Record when eligibility screening was performed.\"\n      data_type: \"date\"\n      required: null\n      unit: null\n      range: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Recruitment and screening, page 3\"\n          confidence: \"medium\"\n      notes:\n        - \"A screening date is implied but not explicitly named as a CRF field.\"\n      inference:\n        kind: \"inferred_supporting_field\"\n        rationale: \"A dated screening assessment is necessary to evaluate look-back periods stated by the protocol.\"\n        confidence_percent: 90\n      coding:\n        status: \"unresolved\"\n        rationale: \"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\"\n    - concept_id: \"inc01_informed_consent\"\n      label: \"Informed consent inclusion criterion met\"\n      purpose: \"Confirm that informed consent has been obtained.\"\n      data_type: \"boolean\"\n      required: null\n      unit: null\n      range: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Inclusion criteria item 1, page 2\"\n          confidence: \"high\"\n        - locator: \"Ethical issues and dissemination, page 7\"\n          confidence: \"high\"\n      notes: []\n      inference:\n        kind: \"protocol_explicit\"\n        rationale: null\n        confidence_percent: 100\n      coding:\n        status: \"unresolved\"\n        rationale: \"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\"\n    - concept_id: \"age_years\"\n      label: \"Age\"\n      purpose: \"Record age in years as evidence for the age eligibility criterion.\"\n      data_type: \"number\"\n      required: null\n      unit: \"years\"\n      range:\n        minimum: null\n        maximum: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Inclusion criteria item 2, page 2\"\n          confidence: \"high\"\n      notes:\n        - \"The inclusion interval is 30 through 65 years.\"\n        - \"The form must retain out-of-range values to document screen failures.\"\n        - \"Integer versus fractional-year precision is not stated.\"\n      inference:\n        kind: \"protocol_explicit\"\n        rationale: null\n        confidence_percent: 100\n      coding:\n        status: \"unresolved\"\n        rationale: \"Official CDASHIG v2.1 mapping review completed; specialist candidate selection remains pending.\"\n    - concept_id: \"height_cm\"\n      label: \"Height\"\n      purpose: \"Record height in centimetres for the BMI calculation.\"\n      data_type: \"number\"\n      required: true\n      unit: \"cm\"\n      range:\n        minimum: null\n        maximum: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Anthropometric measurements, page 5\"\n          confidence: \"high\"\n      notes:\n        - \"The user specified centimetres as the capture unit for this BMI calculation.\"\n      inference:\n        kind: \"protocol_explicit\"\n        rationale: null\n        confidence_percent: 100\n      coding:\n        status: \"unresolved\"\n        rationale: \"CDASHIG v2.1 mapping review is required for the height result.\"\n    - concept_id: \"weight_kg\"\n      label: \"Weight\"\n      purpose: \"Record weight in kilograms for the BMI calculation.\"\n      data_type: \"number\"\n      required: true\n      unit: \"kg\"\n      range:\n        minimum: null\n        maximum: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation: null\n      source_refs:\n        - locator: \"Anthropometric measurements, page 5\"\n          confidence: \"high\"\n      notes:\n        - \"The user specified kilograms as the capture unit for this BMI calculation.\"\n      inference:\n        kind: \"protocol_explicit\"\n        rationale: null\n        confidence_percent: 100\n      coding:\n        status: \"unresolved\"\n        rationale: \"CDASHIG v2.1 mapping review is required for the weight result.\"\n    - concept_id: \"bmi\"\n      label: \"Body mass index (BMI)\"\n      purpose: \"Calculate body mass index from weight in kilograms and height in metres squared.\"\n      data_type: \"number\"\n      required: false\n      unit: \"kg/m²\"\n      range:\n        minimum: null\n        maximum: null\n      options: []\n      visible_when: null\n      required_when: null\n      calculation:\n        type: \"bmi\"\n        height_concept_id: \"height_cm\"\n        weight_concept_id: \"weight_kg\"\n        decimal_places: 2\n      source_refs:\n        - locator: \"Anthropometric measurements, page 5\"\n          confidence: \"high\"\n      notes:\n        - \"The