{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airwayai.example/schemas/crf-contract.meta-schema.json",
  "title": "AirwayAI eCRF contract meta-schema",
  "description": "Validates the required JSON Schema envelope and the x-airwayai renderer extension.",
  "type": "object",
  "required": [
    "$schema",
    "$id",
    "type",
    "additionalProperties",
    "properties",
    "x-airwayai"
  ],
  "properties": {
    "$schema": {
      "const": "https://json-schema.org/draft/2020-12/schema"
    },
    "$id": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "const": "object"
    },
    "additionalProperties": {
      "const": false
    },
    "properties": {
      "type": "object",
      "minProperties": 1
    },
    "required": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "x-airwayai": {
      "$ref": "#/$defs/extension"
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z]{2,3}(?:-[A-Z][A-Za-z0-9]{1,7})?$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "primitive": {
      "type": ["string", "number", "boolean", "null"]
    },
    "predicate": {
      "oneOf": [
        {
          "type": "object",
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/predicate"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/predicate"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not"],
          "properties": {
            "not": {
              "$ref": "#/$defs/predicate"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "path"],
          "properties": {
            "op": {
              "const": "exists"
            },
            "path": {
              "type": "string",
              "pattern": "^/"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "path", "value"],
          "properties": {
            "op": {
              "enum": ["eq", "neq", "lt", "lte", "gt", "gte", "in", "contains"]
            },
            "path": {
              "type": "string",
              "pattern": "^/"
            },
            "value": {
              "oneOf": [
                {
                  "$ref": "#/$defs/primitive"
                },
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/primitive"
                  }
                }
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "option": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": {
          "$ref": "#/$defs/primitive"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        }
      },
      "additionalProperties": false
    },
    "link": {
      "type": "object",
      "required": ["label", "href"],
      "properties": {
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "href": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      },
      "additionalProperties": false
    },
    "fieldConfig": {
      "type": "object",
      "required": ["label", "widget"],
      "properties": {
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "help": {
          "$ref": "#/$defs/localizedText"
        },
        "placeholder": {
          "$ref": "#/$defs/localizedText"
        },
        "widget": {
          "enum": [
            "text",
            "textarea",
            "integer",
            "number",
            "date",
            "radio",
            "select",
            "checkbox_group",
            "boolean",
            "computed",
            "coordinate_3d"
          ]
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "unit": {
          "type": "object",
          "required": ["code", "display"],
          "properties": {
            "code": {
              "type": "string",
              "minLength": 1
            },
            "display": {
              "$ref": "#/$defs/localizedText"
            }
          },
          "additionalProperties": false
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "visibleWhen": {
          "$ref": "#/$defs/predicate"
        },
        "enabledWhen": {
          "$ref": "#/$defs/predicate"
        },
        "requiredWhen": {
          "$ref": "#/$defs/predicate"
        },
        "coordinate": {
          "type": "object",
          "required": ["axes", "unitPath"],
          "properties": {
            "axes": {
              "type": "array",
              "prefixItems": [
                { "const": "x" },
                { "const": "y" },
                { "const": "z" }
              ],
              "items": false,
              "minItems": 3,
              "maxItems": 3
            },
            "unitPath": {
              "type": "string",
              "pattern": "^/"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "fieldLayout": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "const": "field"
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "span": {
          "enum": [1, 2, 3]
        }
      },
      "additionalProperties": false
    },
    "groupLayout": {
      "type": "object",
      "required": ["type", "id", "items"],
      "properties": {
        "type": {
          "const": "group"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9-]*$"
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "columns": {
          "enum": [1, 2, 3]
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fieldLayout"
          }
        }
      },
      "additionalProperties": false
    },
    "sectionLayout": {
      "type": "object",
      "required": ["type", "id", "title", "items"],
      "properties": {
        "type": {
          "const": "section"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9-]*$"
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "collapsible": {
          "type": "boolean"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/fieldLayout" },
              { "$ref": "#/$defs/groupLayout" }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "calculation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["op", "value"],
          "properties": {
            "op": { "const": "value" },
            "value": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "path"],
          "properties": {
            "op": { "const": "path" },
            "path": { "type": "string", "pattern": "^/" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "args"],
          "properties": {
            "op": { "enum": ["add", "subtract", "multiply", "divide"] },
            "args": {
              "type": "array",
              "minItems": 2,
              "items": { "$ref": "#/$defs/calculation" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "extension": {
      "type": "object",
      "required": [
        "contractVersion",
        "formId",
        "schemaVersion",
        "status",
        "defaultLocale",
        "locales",
        "title",
        "fields",
        "layout",
        "computed"
      ],
      "properties": {
        "contractVersion": {
          "const": "1.0.0"
        },
        "formId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "schemaVersion": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
        },
        "status": {
          "enum": ["demo", "draft", "released", "retired"]
        },
        "defaultLocale": {
          "type": "string",
          "minLength": 2
        },
        "locales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "disclaimer": {
          "$ref": "#/$defs/localizedText"
        },
        "fields": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^/"
          },
          "additionalProperties": {
            "$ref": "#/$defs/fieldConfig"
          }
        },
        "layout": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sectionLayout"
          }
        },
        "computed": {
          "type": "object",
          "propertyNames": {
            "pattern": "^/"
          },
          "additionalProperties": {
            "$ref": "#/$defs/calculation"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
